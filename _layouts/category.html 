---
layout: default
title: "分類"
permalink: "/category/:name/"
---

<header>
    <h1 class="page-title">分類：{{ page.category }}</h1>
    <hr class="separator">
</header>

<section>
    <h2>文章列表</h2>
    <ul class="post-list">
        {% for post in site.categories[page.category] %}
            <li>
                <h3><a href="{{ post.url }}">{{ post.title }}</a></h3>
            </li>
        {% endfor %}
    </ul>
</section>